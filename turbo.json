{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "@tedengine/ted#build": {
      "dependsOn": ["^build"],
      "outputs": ["$TURBO_ROOT$/dist/packages/ted/**"]
    },
    "@tedengine/docs#build": {
      "dependsOn": ["^build"],
      "outputs": ["$TURBO_ROOT$/dist/apps/docs/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "outputs": ["$TURBO_ROOT$/coverage/**"]
    }
  }
}
