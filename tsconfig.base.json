{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom", "webworker"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@tedengine/ted": ["./packages/ted/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
